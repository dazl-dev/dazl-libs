{
  "name": "@dazl/dev",
  "version": "1.6.0",
  "description": "Dazl development time utilities.",
  "type": "module",
  "exports": {
    ".": "./dist/jsx-runtime.js",
    "./jsx-runtime": "./dist/jsx-runtime.js",
    "./jsx-dev-runtime": "./dist/jsx-runtime.js",
    "./dazl-vite-plugin": "./dist/dazl-vite-plugin.js",
    "./dazl-postcss-plugin": {
      "require": "./dist/dazl-postcss-plugin.cjs",
      "import": "./dist/dazl-postcss-plugin.js"
    },
    "./dazl-plugin-types": "./dist/dazl-plugin-types.js",
    "./package.json": "./package.json"
  },
  "types": "./dist/jsx-runtime.d.ts",
  "typesVersions": {
    "*": {
      "jsx-runtime": [
        "./dist/jsx-runtime.d.ts"
      ],
      "jsx-dev-runtime": [
        "./dist/jsx-runtime.d.ts"
      ],
      "dazl-vite-plugin": [
        "./dist/dazl-vite-plugin.d.ts"
      ],
      "dazl-postcss-plugin": [
        "./dist/dazl-postcss-plugin.d.ts"
      ],
      "dazl-plugin-types": [
        "./dist/dazl-plugin-types.d.ts"
      ]
    }
  },
  "peerDependencies": {
    "vite": ">=7.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "files": [
    "dist",
    "src",
    "!*/tsconfig.{json,tsbuildinfo}"
  ],
  "keywords": [
    "dazl",
    "react"
  ],
  "author": "Dazl",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dazl-dev/dazl-libs.git",
    "directory": "packages/dev"
  },
  "publishConfig": {
    "access": "public"
  }
}
