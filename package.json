{
  "name": "dazl-libs",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "A collection of utility libraries",
  "scripts": {
    "pretest": "npm run lint && npm run build",
    "test": "npm run test --workspaces --if-present",
    "prebuild": "npm run clean",
    "build": "tsc --build && npm run package --workspaces --if-present",
    "lint": "eslint",
    "clean": "rimraf -g \"./packages/*/dist\"",
    "prettify": "prettier --write ."
  },
  "workspaces": [
    "packages/*"
  ],
  "keywords": [
    "utilities",
    "libraries",
    "workspace"
  ],
  "author": "Dazl",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/browser-chromium": "^1.59.1",
    "@playwright/test": "^1.59.1",
    "@types/chai": "^5.2.3",
    "@types/node": "24",
    "@types/react": "^19.2.14",
    "chai": "^6.2.2",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-no-only-tests": "^3.3.0",
    "eslint-plugin-react-hooks": "^7.1.0",
    "prettier": "^3.8.3",
    "promise-assist": "^2.0.1",
    "react": "^19.2.5",
    "rimraf": "^6.1.3",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8"
  }
}
